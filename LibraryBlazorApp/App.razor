<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(Program).Assembly" PreferExactMatches="@true">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <Authorizing>
                    <div style="height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; background-color: #f5f5f5;">
                        <MudText Typo="Typo.h5" Class="mb-4" Color="Color.Primary">Initialising Library System...</MudText>
                        <div style="width: 300px;">
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="rounded-pill" />
                        </div>
                        <MudText Typo="Typo.caption" Class="mt-2 text-muted">Checking authentication state</MudText>
                    </div>
                </Authorizing>
                <NotAuthorized>
                    <RedirectToLogin />
                </NotAuthorized>
            </AuthorizeRouteView>
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(MainLayout)">
                <p>Sorry, there's nothing at this address.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
