@using LibraryBlazorApp.Models
@using System.Net.Http.Json
@using System.ComponentModel.DataAnnotations
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@success">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="member.FirstName" Label="First Name" Required="true"
                                  RequiredError="First name is required!" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="member.LastName" Label="Last Name" Required="true"
                                  RequiredError="Last name is required!" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="member.Email" Label="Email" Required="true"
                                  RequiredError="Email is required!" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="member.PhoneNumber" Label="Phone Number" Required="true"
                                  RequiredError="Phone is required!" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="member.Address" Label="Address" Lines="2" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker @bind-Date="member.DateOfBirth" Label="Date of Birth" Editable="true"
                                   MaxDate="DateTime.Now" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect @bind-Value="member.MembershipType" Label="Membership Type" Required="true">
                        <MudSelectItem Value="@("Regular")">Regular (3 books)</MudSelectItem>
                        <MudSelectItem Value="@("Premium")">Premium (5 books)</MudSelectItem>
                        <MudSelectItem Value="@("Student")">Student (4 books)</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Success" OnClick="Submit" Disabled="@(!success)">Register</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }

    private bool success;
    private MudForm form;

    private Member member = new Member
    {
        FirstName = "",
        LastName = "",
        Email = "",
        PhoneNumber = "",
        Address = "",
        MembershipType = "Regular",
        IsActive = true
    };

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
        await form.Validate();

        if (form.IsValid)
        {
            try
            {
                var response = await Http.PostAsJsonAsync("api/members", member);

                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Member registered successfully!", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Snackbar.Add($"Error: {error}", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }
}