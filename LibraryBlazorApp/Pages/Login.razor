@page "/login"
@layout LoginLayout
@attribute [AllowAnonymous]

@using LibraryBlazorApp.Models
@using LibraryBlazorApp.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Login - Library Management System</PageTitle>

<div class="login-container">
    <MudContainer MaxWidth="MaxWidth.Small">
        <MudCard Elevation="0" Class="glass-card pa-8">
            
            @* ═══════════════════════════════════════ *@
            @* HEADER *@
            @* ═══════════════════════════════════════ *@
            <div class="logo-container d-flex flex-column align-center">
                <MudIcon Icon="@Icons.Material.Filled.MenuBook" 
                         Class="logo-icon mb-4" />
                <MudText Typo="Typo.h3" Class="title-text mt-2" Align="Align.Center">
                    Library One
                </MudText>
                <MudText Typo="Typo.subtitle1" Class="subtitle-text" Align="Align.Center">
                    @(isLoginMode ? "Welcome back! Please sign in." : "Create your account to get started.")
                </MudText>
            </div>

            <MudCardContent>
                @* ═══════════════════════════════════════ *@
                @* TAB SELECTOR *@
                @* ═══════════════════════════════════════ *@
                <MudTabs @bind-ActivePanelIndex="activeTab" 
                         Centered="true" 
                         Rounded="true" 
                         ApplyEffectsToContainer="true" 
                         Class="mt-6 mb-6 tab-selector"
                         Color="Color.Primary"
                         SliderColor="Color.Secondary">
                    
                    @* ─────────── LOGIN TAB ─────────── *@
                    <MudTabPanel Text="LOGIN" Icon="@Icons.Material.Filled.Fingerprint">
                        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                            <DataAnnotationsValidator />

                            <MudTextField @bind-Value="loginModel.Email"
                                          Label="Email Address"
                                          Variant="Variant.Outlined"
                                          InputType="InputType.Email"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.AlternateEmail"
                                          AdornmentColor="Color.Primary"
                                          Class="input-field mt-6"
                                          For="@(() => loginModel.Email)" />

                            <MudTextField @bind-Value="loginModel.Password"
                                          Label="Password"
                                          Variant="Variant.Outlined"
                                          InputType="@loginPasswordInputType"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@loginPasswordIcon"
                                          AdornmentColor="Color.Primary"
                                          OnAdornmentClick="ToggleLoginPasswordVisibility"
                                          Class="input-field mt-4"
                                          For="@(() => loginModel.Password)" />

                            @if (!string.IsNullOrEmpty(loginError))
                            {
                                <MudAlert Severity="Severity.Error" Class="mt-4 rounded-lg" Dense="true" Variant="Variant.Filled">
                                    @loginError
                                </MudAlert>
                            }

                            <div class="d-flex justify-space-between align-center mt-4">
                                <MudCheckBox T="bool" Label="Remember me" Color="Color.Primary" Dense="true" />
                                <MudLink Typo="Typo.body2" Color="Color.Primary">Forgot password?</MudLink>
                            </div>

                            <MudButton ButtonType="ButtonType.Submit"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       FullWidth="true"
                                       Class="modern-btn mt-6 mb-2"
                                       Size="Size.Large"
                                       Disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                    <MudText Class="ms-2">SECURE SIGNING IN...</MudText>
                                }
                                else
                                {
                                    <MudText>SIGN IN</MudText>
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="ml-2" />
                                }
                            </MudButton>
                        </EditForm>
                    </MudTabPanel>

                    @* ─────────── REGISTER TAB ─────────── *@
                    <MudTabPanel Text="REGISTER" Icon="@Icons.Material.Filled.PersonAddAlt1">
                        <EditForm Model="@registerModel" OnValidSubmit="HandleRegister">
                            <DataAnnotationsValidator />

                            <MudTextField @bind-Value="registerModel.Username"
                                          Label="Full Name"
                                          Variant="Variant.Outlined"
                                          InputType="InputType.Text"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Badge"
                                          AdornmentColor="Color.Primary"
                                          Class="input-field mt-6"
                                          For="@(() => registerModel.Username)" />

                            <MudTextField @bind-Value="registerModel.Email"
                                          Label="Email Address"
                                          Variant="Variant.Outlined"
                                          InputType="InputType.Email"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.AlternateEmail"
                                          AdornmentColor="Color.Primary"
                                          Class="input-field mt-4"
                                          For="@(() => registerModel.Email)" />

                            <MudTextField @bind-Value="registerModel.Password"
                                          Label="Create Password"
                                          Variant="Variant.Outlined"
                                          InputType="@registerPasswordInputType"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@registerPasswordIcon"
                                          AdornmentColor="Color.Primary"
                                          OnAdornmentClick="ToggleRegisterPasswordVisibility"
                                          Class="input-field mt-4"
                                          For="@(() => registerModel.Password)" />

                            <MudTextField @bind-Value="registerModel.ConfirmPassword"
                                          Label="Confirm Password"
                                          Variant="Variant.Outlined"
                                          InputType="@confirmPasswordInputType"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@confirmPasswordIcon"
                                          AdornmentColor="Color.Primary"
                                          OnAdornmentClick="ToggleConfirmPasswordVisibility"
                                          Class="input-field mt-4"
                                          For="@(() => registerModel.ConfirmPassword)" />

                            @if (!string.IsNullOrEmpty(registerError))
                            {
                                <MudAlert Severity="Severity.Error" Class="mt-4 rounded-lg" Dense="true" Variant="Variant.Filled">
                                    @registerError
                                </MudAlert>
                            }

                            @if (!string.IsNullOrEmpty(registerSuccess))
                            {
                                <MudAlert Severity="Severity.Success" Class="mt-4 rounded-lg" Dense="true" Variant="Variant.Filled">
                                    @registerSuccess
                                </MudAlert>
                            }

                            <MudButton ButtonType="ButtonType.Submit"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       FullWidth="true"
                                       Class="modern-btn mt-6 mb-2"
                                       Size="Size.Large"
                                       Disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                    <MudText Class="ms-2">CREATING ACCOUNT...</MudText>
                                }
                                else
                                {
                                    <MudText>JOIN NOW</MudText>
                                    <MudIcon Icon="@Icons.Material.Filled.RocketLaunch" Class="ml-2" />
                                }
                            </MudButton>
                        </EditForm>
                    </MudTabPanel>
                </MudTabs>
            </MudCardContent>
        </MudCard>
    </MudContainer>
</div>


@code {
    // ═══════════════════════════════════════
    // MODELS
    // ═══════════════════════════════════════
    private LoginModel loginModel = new();
    private RegisterModel registerModel = new();

    // ═══════════════════════════════════════
    // STATE
    // ═══════════════════════════════════════
    private bool isLoading;
    private string loginError = "";
    private string registerError = "";
    private string registerSuccess = "";
    private int activeTab;
    private bool isLoginMode => activeTab == 0;

    // Password visibility toggles
    private bool loginPasswordVisible;
    private bool registerPasswordVisible;
    private bool confirmPasswordVisible;

    private InputType loginPasswordInputType => loginPasswordVisible ? InputType.Text : InputType.Password;
    private InputType registerPasswordInputType => registerPasswordVisible ? InputType.Text : InputType.Password;
    private InputType confirmPasswordInputType => confirmPasswordVisible ? InputType.Text : InputType.Password;

    private string loginPasswordIcon => loginPasswordVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    private string registerPasswordIcon => registerPasswordVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    private string confirmPasswordIcon => confirmPasswordVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;

    // ═══════════════════════════════════════
    // HANDLERS
    // ═══════════════════════════════════════

    private async Task HandleLogin()
    {
        isLoading = true;
        loginError = "";

        var result = await AuthService.LoginAsync(loginModel);

        if (result.Success)
        {
            Navigation.NavigateTo("/", forceLoad: true);
        }
        else
        {
            loginError = result.Message;
        }

        isLoading = false;
    }

    private async Task HandleRegister()
    {
        isLoading = true;
        registerError = "";
        registerSuccess = "";

        var result = await AuthService.RegisterAsync(registerModel);

        if (result.Success)
        {
            Navigation.NavigateTo("/", forceLoad: true);
        }
        else
        {
            registerError = result.Message;
        }

        isLoading = false;
    }

    private void ToggleLoginPasswordVisibility() => loginPasswordVisible = !loginPasswordVisible;
    private void ToggleRegisterPasswordVisibility() => registerPasswordVisible = !registerPasswordVisible;
    private void ToggleConfirmPasswordVisibility() => confirmPasswordVisible = !confirmPasswordVisible;
}
