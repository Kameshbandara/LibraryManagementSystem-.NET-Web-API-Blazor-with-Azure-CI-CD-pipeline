@using LibraryBlazorApp.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@success">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="book.Title" Label="Title" Required="true"
                                  RequiredError="Title is required!" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="book.Author" Label="Author" Required="true"
                                  RequiredError="Author is required!" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="book.ISBN" Label="ISBN" Required="true"
                                  RequiredError="ISBN is required!" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="book.Publisher" Label="Publisher" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="book.Description" Label="Description"
                                  Lines="3" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="book.PublishedYear" Label="Published Year"
                                     Min="1800" Max="2100" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="book.Pages" Label="Pages" Min="1" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="book.TotalCopies" Label="Total Copies"
                                     Min="1" Required="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect @bind-Value="book.Category" Label="Category" Required="true">
                        <MudSelectItem Value="@("Programming")">Programming</MudSelectItem>
                        <MudSelectItem Value="@("Mathematices")">Mathematices</MudSelectItem>
                        <MudSelectItem Value="@("Fiction")">Fiction</MudSelectItem>
                        <MudSelectItem Value="@("Science")">Science</MudSelectItem>
                        <MudSelectItem Value="@("History")">History</MudSelectItem>
                        <MudSelectItem Value="@("Music")">Music</MudSelectItem>
                        <MudSelectItem Value="@("Biography")">Biography</MudSelectItem>
                        <MudSelectItem Value="@("Other")">Other</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="book.Language" Label="Language" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="book.CoverImageUrl" Label="Cover Image URL" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField @bind-Value="book.Rating" Label="Rating (0.0 - 5.0)" Min="0.0" Max="5.0" Step="0.1" Format="F1" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!success)">Add Book</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }

    private bool success;
    private MudForm form;

    private Book book = new Book
    {
        Title = "",
        Author = "",
        ISBN = "",
        Description = "",
        Publisher = "",
        Language = "English",
        Category = "Programming",
        PublishedYear = DateTime.Now.Year,
        Pages = 0,
        TotalCopies = 1,
        AvailableCopies = 1,
        Price = 0,
        Rating = 0
    };

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
        await form.Validate();

        if (form.IsValid)
        {
            try
            {
                book.AvailableCopies = book.TotalCopies;
                book.Rating = Math.Round(book.Rating, 1);

                var response = await Http.PostAsJsonAsync("api/books", book);

                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Book added successfully!", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Snackbar.Add($"Error: {error}", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }
}